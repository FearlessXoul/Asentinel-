# ══════════════════════════════════════════════
# ASENTINEL — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub
# ══════════════════════════════════════════════

# ── BACKEND (Railway) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_ELITE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
JWT_SECRET=replace_with_any_long_random_string_min_32_chars
FRONTEND_URL=https://asentinel.app
PORT=3001

# ── TELEGRAM BOT (Railway) ─────────────────────
BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BACKEND_URL=https://asentinel-api.railway.app
BOT_SECRET=replace_with_shared_secret_between_bot_and_api

# ── FRONTEND (Vercel) ──────────────────────────
VITE_API_URL=https://asentinel-api.railway.app
VITE_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_ELITE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx

